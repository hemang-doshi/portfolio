# Instagram Login credentials (from developers.facebook.com)
INSTAGRAM_APP_ID=YOUR_INSTAGRAM_APP_ID
INSTAGRAM_APP_SECRET=YOUR_INSTAGRAM_APP_SECRET
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# Filled in automatically after visiting /api/instagram/connect
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Protect the /api/instagram/refresh cron route
CRON_SECRET=
